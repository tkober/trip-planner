# Frontend build-time configuration. Copy to `.env` and adjust.
# Read by scripts/generate-env.mjs (prestart / prebuild hooks). Variables set on
# the command line take precedence over this file.

# Persistence backend: "indexeddb" (default, browser-local) or "http" (backend).
STORAGE_BACKEND=http

# Base URL of the FastAPI backend when STORAGE_BACKEND=http.
API_BASE_URL=http://127.0.0.1:8000

# New-trip timezone defaults (optional).
# DEFAULT_DEPARTURE_TZ=
# DEFAULT_TRIP_TZ=Asia/Tokyo
