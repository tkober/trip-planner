# Frontend build-time configuration. Copy to `.env` and adjust.
# Read by scripts/generate-env.mjs (prestart / prebuild hooks). Variables set on
# the command line take precedence over this file.

# Persistence backend: "indexeddb" (default, browser-local) or "http" (backend).
STORAGE_BACKEND=http

# Base URL of the FastAPI backend when STORAGE_BACKEND=http.
API_BASE_URL=http://127.0.0.1:8000

# New-trip timezone defaults (optional).
# DEFAULT_DEPARTURE_TZ=
# DEFAULT_TRIP_TZ=Asia/Tokyo

# Selectable "kind" options for train / bus transport (comma-separated).
# When set, these REPLACE the built-in defaults shown below.
# TRAIN_KINDS=Local train,Rapid,Limited express,Shinkansen
# BUS_KINDS=City bus,Long-distance coach,Overnight,Hop on/off

# Selectable currency codes for the cost picker (comma-separated). EUR is the
# base currency; non-EUR costs need an exchange rate in the trip Overview. The
# user can still type any 3-letter code. When set, REPLACES the default below.
# CURRENCIES=EUR,USD,JPY
