# Connection target: host/port/database only — no credentials, no driver scheme.
# Credentials come from the role-specific vars below.
DB_URL=postgresql://192.168.2.230:5432/trip_planner

# App role — used for all regular runtime CRUD. Cannot perform DDL.
DB_USER=trip_planner_app
DB_PASSWORD=

# Owner role — used ONLY at startup to create the table and grant the app role.
DB_OWNER_USER=trip_planner_owner
DB_OWNER_PASSWORD=

# Comma-separated list of allowed CORS origins (the Angular dev server origin).
# Use "*" to allow any origin (fine for local testing).
CORS_ORIGINS=http://localhost:4200
